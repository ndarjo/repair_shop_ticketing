#: routes/admin.py:98
msgid "User created successfully"
msgstr "Потребителят е създаден успешно"

#: routes/admin.py:103
msgid "A database error occurred while creating the user."
msgstr "Възникна грешка в базата данни при създаването на потребителя."

#: routes/admin.py:118 routes/admin.py:207
msgid "User not found."
msgstr "Потребителят не е намерен."

#: routes/admin.py:125
msgid ""
"Security Policy: Administrative accounts can only be modified by their "
"respective owners."
msgstr ""
"Правила за сигурност: Административните акаунти могат да се променят само от"
" съответните им собственици."

#: routes/admin.py:141
msgid "Full name and email are required."
msgstr "Необходими са пълно име и имейл."

#: routes/admin.py:147
msgid ""
"Security Warning: You cannot deactivate your own administrative account. "
"Deactivation ignored."
msgstr ""
"Предупреждение за сигурност: Не можете да деактивирате собствения си "
"административен акаунт. Деактивирането е игнорирано."

#: routes/admin.py:153
msgid "This email address is already associated with another account."
msgstr "Този имейл адрес вече е свързан с друг акаунт."

#: routes/admin.py:168
msgid ""
"Security Error: You cannot demote your own account from the superuser role."
msgstr ""
"Грешка в сигурността: Не можете да понижите собствения си акаунт от ролята "
"на суперпотребител."

#: routes/admin.py:182
msgid "User updated"
msgstr "Потребителят е актуализиран"

#: routes/admin.py:187
msgid "A database error occurred while updating the user."
msgstr "Възникна грешка в базата данни при актуализирането на потребителя."

#: routes/admin.py:202
msgid "Security Error: You cannot delete your own account."
msgstr "Грешка в сигурността: Не можете да изтриете собствения си акаунт."

#: routes/admin.py:214
msgid ""
"Security Policy: Administrative accounts cannot be deleted through the "
"management interface."
msgstr ""
"Правила за сигурност: Административните акаунти не могат да бъдат изтривани "
"през интерфейса за управление."

#: routes/admin.py:226
msgid ""
"Cannot delete user: This account has linked activity (tickets, notes, or "
"payments). Deactivate the account instead to preserve history."
msgstr ""
"Не може да се изтрие потребител: Този акаунт има свързана дейност (билети, "
"бележки или плащания). Вместо това деактивирайте акаунта, за да запазите "
"историята."

#: routes/admin.py:232
msgid "User account permanently removed."
msgstr "Потребителският акаунт е премахнат за постоянно."

#: routes/admin.py:236
msgid "Error removing user from database."
msgstr "Грешка при премахване на потребител от базата данни."

#: routes/admin.py:252 routes/admin.py:285
msgid "Location name is required."
msgstr "Изисква се име на местоположение."

#: routes/admin.py:254
msgid "A location with this name already exists."
msgstr "Местоположение с това име вече съществува."

#: routes/admin.py:260
#, python-format
msgid "New location \"%(name)s\" created successfully."
msgstr "Новото местоположение „ %(name)s “ е създадено успешно."

#: routes/admin.py:265
msgid "Error saving new location."
msgstr "Грешка при запазване на ново местоположение."

#: routes/admin.py:280 routes/admin.py:318
msgid "Location not found."
msgstr "Местоположението не е намерено."

#: routes/admin.py:293
msgid "Another location with this name already exists."
msgstr "Друго местоположение с това име вече съществува."

